{
  "name": "author-app",
  "version": "1.1.19",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "npm run dev & npx electron . --dev",
    "electron:build": "node -e \"const fs=require('fs');['dist','.next'].forEach(d=>{if(fs.existsSync(d)){fs.rmSync(d,{recursive:true,force:true})}})\" && npx next build && npx electron-builder --win",
    "electron:start": "npx electron ."
  },
  "dependencies": {
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-character-count": "^3.19.0",
    "@tiptap/extension-color": "^3.19.0",
    "@tiptap/extension-font-family": "^3.19.0",
    "@tiptap/extension-highlight": "^3.19.0",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/extension-subscript": "^3.19.0",
    "@tiptap/extension-superscript": "^3.19.0",
    "@tiptap/extension-task-item": "^3.19.0",
    "@tiptap/extension-task-list": "^3.19.0",
    "@tiptap/extension-text-align": "^3.19.0",
    "@tiptap/extension-text-style": "^3.19.0",
    "@tiptap/extension-underline": "^3.19.0",
    "@tiptap/pm": "^3.19.0",
    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "docx": "^9.6.0",
    "electron-updater": "^6.8.3",
    "idb-keyval": "^6.2.2",
    "jszip": "^3.10.1",
    "katex": "^0.16.28",
    "mammoth": "^1.11.0",
    "next": "16.1.6",
    "pdf-parse": "^1.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tiptap-markdown": "^0.9.0",
    "tokenx": "^1.3.0",
    "undici": "^7.22.0",
    "word-extractor": "^1.0.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4"
  },
  "build": {
    "appId": "com.yuanshijilong.author",
    "productName": "Author",
    "publish": [
      {
        "provider": "github",
        "owner": "YuanShiJiLoong",
        "repo": "author"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": [
          "**/*",
          "!dist",
          "!dist/**/*",
          "!.git",
          "!.git/**/*",
          "!data",
          "!data/**/*",
          "!electron",
          "!electron/**/*",
          "!*.png",
          "!*.md",
          "!Caddyfile",
          "!Dockerfile",
          "!docker-compose*.yml",
          "!afterPack.js",
          "!eslint.config.mjs",
          "!jsconfig.json",
          "!postcss.config.mjs",
          "!next.config.mjs",
          "!package-lock.json",
          "!LICENSE",
          "!.npmrc",
          "!.env*",
          "!.gitignore",
          "!.dockerignore"
        ]
      },
      {
        "from": ".next/static",
        "to": "standalone/.next/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public",
        "to": "standalone/public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "afterPack": "./afterPack.js",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh"
    }
  }
}